---
cluster: '*'
form:
  - api_key
  - overwrite_settings
  - cluster
  - sif_version
  - working_dir
  - bc_num_hours
  - bc_email_on_started
attributes:
  api_key:
    widget: "text_field"
    label: "SLAC AI API Key"
    help: |
      Get your key at [KB0015379](https://it.slac.stanford.edu/support/KB0015379).
    required: true
  overwrite_settings:
    widget: "check_box"
    label: "Overwrite existing settings"
    help: |
      Overwrites `~/.claude/settings.json` with the API key above. Use after a key rotation or to reset to defaults.
    value: "0"
  cluster:
    help: |
      Interactive node to run Claude Code on. Choose the cluster closest to your data.
  sif_version:
    widget: "select"
    label: "Claude Code Version"
    help: |
      Version of Claude Code to run. Latest is recommended.
    options:
      <%
        sifs = Dir.glob("/sdf/sw/claude-code/claude-code_*.sif")
          .sort_by { |path| File.basename(path, '.sif').sub('claude-code_', '').split('.').map(&:to_i) }
          .reverse
        sifs.each_with_index do |path, i|
          version = File.basename(path, '.sif').sub('claude-code_', '')
          label = i == 0 ? "#{version} (latest)" : version
      %>
      - ["<%= label %>", "<%= path %>"]
      <% end %>
  working_dir:
    widget: "text_field"
    label: "Working Directory"
    value: ""
    placeholder: "$HOME (default)"
    help: |
      Directory where Claude Code will start. Leave blank for your home directory.
  bc_num_hours:
    widget: "number_field"
    label: "Session Duration (hours)"
    value: 8
    help: |
      How long to keep the session alive (max 168 hours).
    min: 1
    max: 168
    step: 1
