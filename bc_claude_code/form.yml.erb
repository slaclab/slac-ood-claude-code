---
cluster: '*'
form:
  - api_key
  - overwrite_settings
  - cluster
  - sif_version
  - working_dir
  - bc_num_hours
  - bc_email_on_started
attributes:
  api_key:
    widget: "text_field"
    label: "SLAC AI API Key"
    help: |
      Your LiteLLM API key for ai-api.slac.stanford.edu. Get one at the
      [AI API Portal](https://ai-api.slac.stanford.edu).

      Written to `~/.claude/settings.json` on launch. Check **Overwrite existing
      settings** below to replace an existing config (e.g. after a key rotation).
    required: true
  overwrite_settings:
    widget: "check_box"
    label: "Overwrite existing settings"
    help: |
      If checked, `~/.claude/settings.json` will be overwritten with the API key
      above. Use this if your key has been rotated or you want to reset to defaults.
      **Your existing settings will be lost.**
    value: "0"
  sif_version:
    widget: "select"
    label: "Claude Code Version"
    help: |
      Version of Claude Code to run. "latest" is recommended for most users.
      Older versions are available if you need to pin to a specific release.
    options:
      <%
        sifs = Dir.glob("/sdf/sw/claude-code/claude-code_*.sif")
          .sort_by { |path| File.basename(path, '.sif').sub('claude-code_', '').split('.').map(&:to_i) }
          .reverse
        sifs.each_with_index do |path, i|
          version = File.basename(path, '.sif').sub('claude-code_', '')
          label = i == 0 ? "#{version} (latest)" : version
      %>
      - ["<%= label %>", "<%= path %>"]
      <% end %>
  working_dir:
    widget: "text_field"
    label: "Working Directory"
    value: ""
    placeholder: "$HOME (default)"
    help: |
      Directory where Claude Code will start. Leave blank to use your home
      directory. Must be an existing directory you have read/write access to.
  bc_num_hours:
    widget: "number_field"
    label: "Session Duration (hours)"
    value: 8
    help: |
      Number of hours for the Claude Code session. Maximum is limited
      by the cluster's site_timeout (typically 168 hours / 7 days).
    min: 1
    max: 168
    step: 1
