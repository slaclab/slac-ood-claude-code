---
cluster: '*'
form:
  - sif_version
  - llm_provider
  - slac_bedrock_key
  - sdf_sage_repo
  - sdf_sage_provider
  - cluster
  - working_dir
  - apptainer_bind_mounts
  - bc_num_hours
  - bc_email_on_started
  - clear_settings
attributes:
  llm_provider:
    widget: "select"
    label: "LLM Provider"
    help: " "
    options:
      - ["Bedrock (personal API key)", "bedrock"]
      - ["SDF-SAGE (facility allocation)", "sdf_sage"]
  slac_bedrock_key:
    widget: "text_field"
    label: "SLAC AI API Key"
    help: |
      Request a [SLAC AI API Bedrock Key](https://slacprod.servicenowservices.com/it_services?id=sc_cat_item&sys_id=515f28711b607110c5d320eae54bcb64&sysparm_category=d65827c46fd921009c4235af1e3ee434).
    required: false
  sdf_sage_provider:
    widget: "select"
    label: "LLM Provider"
    help: |
      The routing backend within SDF-SAGE. Use `copilot` unless told otherwise by your experiment's computing coordinator.
    options:
      - ["copilot", "copilot"]
      - ["s3df", "s3df"]
      - ["bedrock", "bedrock"]
  sdf_sage_repo:
    widget: "text_field"
    label: "Coact Repo"
    placeholder: "e.g. scs:default"
    help: |
      Your S3DF facility and repo allocation. Enter either:
      - `facility` — uses `facility:default` automatically
      - `facility:repo` — uses the specified repo

      Contact your experiment's computing coordinator if unsure of your facility or repo name.
      Authentication will happen automatically when the session starts.
  cluster:
    label: "Run on Cluster"
  sif_version:
    widget: "select"
    label: "Claude Code Version"
    help: |
      Version of Claude Code to run. Latest is recommended.
    options:
      <%
        sifs = Dir.glob("/sdf/sw/claude-code/claude-code_*.sif")
          .sort_by { |path| File.basename(path, '.sif').sub('claude-code_', '').split('.').map(&:to_i) }
          .reverse
        sifs.each_with_index do |path, i|
          version = File.basename(path, '.sif').sub('claude-code_', '')
          label = i == 0 ? "#{version} (latest)" : version
      %>
      - ["<%= label %>", "<%= path %>"]
      <% end %>
  working_dir:
    widget: "text_field"
    label: "Working Directory"
    value: ""
    placeholder: "$HOME (default)"
    help: |
      Directory where Claude Code will start. Leave blank for your home directory.
  apptainer_bind_mounts:
    widget: "text_field"
    label: "Additional Bind Mounts"
    value: ""
    placeholder: "e.g. /sdf/data/rubin:ro,/sdf/scratch/rubin"
    help: |
      Extra paths to bind-mount into the container, comma-separated.
      Each entry may include `:ro` (read-only) or `:rw` (read-write).
      The standard mounts (`/sdf`, `/fs`, `/lscratch`) are always included.
  bc_num_hours:
    widget: "number_field"
    label: "Session Duration (hours)"
    value: 8
    help: |
      How long to keep the session alive (max 168 hours).
    min: 1
    max: 168
    step: 1
  clear_settings:
    widget: "check_box"
    label: "Clear settings.json"
    help: |
      Deletes `~/.claude/settings.json` before starting, allowing Claude Code
      to recreate it from scratch. Use after a major config reset or corruption.
      Your provider and API key will be written fresh. **All other customisations
      (permissions, keybindings, etc.) will be lost.**
    value: "0"
